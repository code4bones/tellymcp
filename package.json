{
  "name": "telegram_mcp",
  "version": "1.0.0",
  "description": "Telegram Human-in-the-Loop MCP Server",
  "main": "dist/services/features/telegram-mcp/runtime.service.js",
  "files": [
    "dist"
  ],
  "_moduleAliases": {
    "@src": "src",
    "@core": "src/services/features/core"
  },
  "scripts": {
    "dev:gw": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_EXPERIMENTAL_RESOLVER=1 NODE_OPTIONS=--openssl-legacy-provider ts-node ./node_modules/moleculer/bin/moleculer-runner.js src/services --config src/moleculer.config.ts --envfile ./.env-dev --hot --mask \"**/*.service.ts\"",
    "dev:gw:telegram": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_EXPERIMENTAL_RESOLVER=1 NODE_OPTIONS=--openssl-legacy-provider ts-node ./node_modules/moleculer/bin/moleculer-runner.js src/services/features/telegram-mcp --config src/moleculer.config.ts --envfile ./.env-dev --hot --mask \"**/*.service.ts\"",
    "dev": "yarn dev:gw",
    "dev:watch": "yarn dev:gw",
    "dev:service": "yarn dev:gw",
    "dev:tmux-proxy": "tsx watch src/services/features/telegram-mcp/src/app/tmux-proxy.ts",
    "build": "tsc -p tsconfig.json",
    "start": "yarn start:gw",
    "start:gw": "node ./node_modules/moleculer/bin/moleculer-runner.js dist/services --config dist/moleculer.config.js --mask \"**/*.service.js\"",
    "start:gw:telegram": "node ./node_modules/moleculer/bin/moleculer-runner.js dist/services/features/telegram-mcp --config dist/moleculer.config.js --mask \"**/*.service.js\"",
    "start:tmux-proxy": "node dist/services/features/telegram-mcp/src/app/tmux-proxy.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node -e \"console.log('No tests configured yet')\"",
    "test:watch": "node -e \"console.log('No tests configured yet')\""
  },
  "repository": "gitlab:prj/mcp/telegram_mcp.git",
  "author": "code4bones <p.olesov@code4bones.online>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@apollo/server": "4.3.1",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/storage-redis": "^2.5.1",
    "@graphql-tools/schema": "^10.0.33",
    "@hapi/accept": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "apollo-server-core": "^3.13.0",
    "axios": "^1.16.0",
    "busboy": "^1.6.0",
    "connect-redis": "^9.0.0",
    "cookie-parse": "^0.4.0",
    "cookie-parser": "^1.4.7",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "grammy": "^1.38.3",
    "graphql": "^16.14.0",
    "graphql-redis-subscriptions": "^2.7.0",
    "graphql-scalars": "^1.25.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2",
    "graphql-ws": "5.11.2",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "knex": "^3.2.10",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "minio": "^8.0.7",
    "module-alias": "^2.3.4",
    "moleculer": "^0.15.0",
    "moleculer-web": "^0.11.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.7",
    "object-hash": "^3.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "socks-proxy-agent": "^8.0.5",
    "streamifier": "^0.1.1",
    "ws": "^8.20.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
