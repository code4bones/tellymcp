# Optional tmux host proxy when service runs in Docker and tmux lives on host.
# TMUX_PROXY_URL=http://host.docker.internal:8788
# TMUX_PROXY_TOKEN=your-token

# Telegram bot token for this client node.
TELEGRAM_BOT_TOKEN=8397631986:AAEIIjbmi7GnYvBNETm_qwa-XwPkmgo8KtE
# Telegram bot username, with or without @.
TELEGRAM_BOT_USERNAME=@leechmcpbot
# Optional project label shown in prompts and notes.
# PROJECT_NAME=
# Telegram polling interval in milliseconds.
TELEGRAM_POLL_INTERVAL_MS=2000
# Timeout for Telegram long operations in seconds.
TELEGRAM_DEFAULT_TIMEOUT_SECONDS=10
# Max chars copied into request context blocks.
TELEGRAM_MAX_CONTEXT_CHARS=3000
# Max chars for question text snippets.
TELEGRAM_MAX_QUESTION_CHARS=1000
# Max chars per outbound Telegram message chunk.
TELEGRAM_MAX_MESSAGE_CHARS=3900
# How many inbox messages a batch read returns.
TELEGRAM_INBOX_BATCH_SIZE=5
# Redis TTL for temporary callback/menu payloads.
TELEGRAM_MENU_PAYLOAD_TTL_SECONDS=300

# Local MCP HTTP endpoint exposed to agent.
MCP_HTTP_HOST=0.0.0.0
# Local MCP HTTP port exposed to agent.
MCP_HTTP_PORT=8787
# MCP path served by the HTTP endpoint.
MCP_HTTP_PATH=/mcp
# Bearer token for MCP HTTP endpoint.
MCP_HTTP_BEARER_TOKEN=very-secret-bearer
# Enables debug helper routes under MCP HTTP service.
MCP_HTTP_ENABLE_DEBUG_ROUTES=true
# Enables explicit prune route for maintenance/debug.
MCP_HTTP_ENABLE_PRUNE_ROUTE=false
# Legacy scope name kept for compatibility.
MCP_VFS_SCOPE=mcp

# Redis host for all runtime/session/menu state.
REDIS_HOST=localhost
# Redis port.
REDIS_PORT=6379
# Redis DB index.
REDIS_DB=1
# Optional Redis username.
# REDIS_USERNAME=
# Optional Redis password.
# REDIS_PASSWORD=

# Queue mode for inbound requests: queue or reject.
MODE=reject
# Pair code TTL in seconds.
PAIR_CODE_TTL_SECONDS=300

# Optional outbound proxy type: http or socks5.
PROXY_USE=http
# HTTP proxy URL used when PROXY_USE=http.
HTTP_PROXY=http://code4bones:Zz12345678**@c4b.undoo.ru:33128
# SOCKS5 proxy URL used when PROXY_USE=socks5.
# SOCKS5_PROXY=

# Enable/disable tmux nudges globally.
TMUX_NUDGE_ENABLED=true
# Debounce before sending tmux nudge.
TMUX_NUDGE_DEBOUNCE_SECONDS=10
# Cooldown between tmux nudges for same session.
TMUX_NUDGE_COOLDOWN_SECONDS=30
# Default tmux nudge text for inbox messages.
TMUX_NUDGE_MESSAGE=проверь inbox и обработай сообщения
# Tmux nudge text for partner/local/collab notes.
TMUX_PARTNER_NUDGE_MESSAGE=не inbox: прочитай SHARED_INDEX.md и partner note
# Tmux capture mode: visible or lines.
TMUX_CAPTURE_MODE=visible
# Number of lines to capture when TMUX_CAPTURE_MODE=lines.
TMUX_CAPTURE_LINES=300
# Optional explicit tmux socket path.
# TMUX_SOCKET_PATH=

# Local go tmux-proxy bind host.
TMUX_PROXY_HOST=0.0.0.0
# Local go tmux-proxy bind port.
TMUX_PROXY_PORT=8788

# Enables Telegram Mini App / Live view.
WEBAPP_ENABLED=true
# Base path served by backend for Mini App.
WEBAPP_BASE_PATH=/webapp
# Public Mini App URL shown to Telegram.
WEBAPP_PUBLIC_URL=https://builder.undoo.ru/api/webapp
# How long Telegram initData is accepted, seconds.
WEBAPP_INITDATA_TTL_SECONDS=300
# Live session TTL in seconds.
WEBAPP_SESSION_TTL_SECONDS=900
# Mini App launch behavior: default, expand, or fullscreen.
WEBAPP_LAUNCH_MODE=fullscreen
# How many panes/screens are visible in Live view.
WEBAPP_VISIBLE_SCREENS=2
# Browser-side polling interval for legacy UI refresh paths.
WEBAPP_POLL_INTERVAL_MS=2000
# Cooldown between user actions in Live UI.
WEBAPP_ACTION_COOLDOWN_MS=150

# Directory under workspace for local exchange files.
MCP_XCHANGE_DIR=.mcp-xchange

# Browser feature enabled.
BROWSER_ENABLED=true
# Launch browser headless.
BROWSER_HEADLESS=false
# Open devtools on browser launch.
BROWSER_DEVTOOLS=false
# Frontend/browser target address.
BROWSER_ADDRESS=http://localhost:5173
# Default browser operation timeout in ms.
BROWSER_TIMEOUT_MS=20000
# Max buffered browser events.
BROWSER_MAX_EVENTS=200
# Playwright waitUntil mode.
BROWSER_WAIT_UNTIL=load
# Optional explicit browser executable path.
# BROWSER_EXECUTABLE_PATH=
# Optional browser channel: chrome|chromium|msedge.
# BROWSER_CHANNEL=chrome
# Optional Playwright slowMo in ms.
BROWSER_SLOW_MO_MS=0

# Distributed mode: client, gateway, both.
DISTRIBUTED_MODE=client
# Public HTTP gateway base URL.
GATEWAY_PUBLIC_URL=https://builder.undoo.ru/api/gateway
# Local gateway bind host for direct HTTP server if mode changes.
GATEWAY_BIND_HOST=127.0.0.1
# Local gateway bind port for direct HTTP server if mode changes.
GATEWAY_BIND_PORT=8790
# Public WebSocket URL for client<->gateway control plane.
GATEWAY_WS_URL=wss://builder.undoo.ru/api/gateway/ws
# WebSocket path mounted on shared backend ingress.
GATEWAY_WS_PATH=/api/gateway/ws
# Optional bearer token protecting gateway endpoints.
# GATEWAY_AUTH_TOKEN=
# Legacy DB URL field kept for compatibility.
# GATEWAY_DATABASE_URL=
# Legacy S3 relay fields kept for compatibility.
# GATEWAY_S3_ENDPOINT=
# GATEWAY_S3_BUCKET=
# GATEWAY_S3_ACCESS_KEY=
# GATEWAY_S3_SECRET_KEY=

#### Shared runtime identity

# Moleculer namespace.
NAMESPACE=mcp
# Node id for this client process.
NODE_ID=client
# Shared backend HTTP port if local API service is exposed.
PORT=8080

# GraphQL tracing enabled on shared backend.
GQL_TRACE=true
# Include GraphQL stack traces.
GQL_ERROR_STACK=true
# Restrict GraphQL playground.
RESTRICT_PLAYGROUND=false
# Legacy log formatter mode.
LOGFORMATTER=short
# Optional Moleculer trace.
# MOLECULER_TRACE=1
# Log retention in days.
LOG_FILE_RETENTION_DAYS=7
# Write logs to files.
LOG_FILE_ENABLED=true
# Log folder.
LOG_FILE_FOLDER=./logs
# Log filename pattern.
LOG_FILE_NAME=dev-{date}.log
# Enable in-app logfeed stream.
ENABLE_LOGFEED=0
# Application log level.
LOG_LEVEL=info

# Hosts that bypass proxy.
NO_PROXY=localhost,127.0.0.1,s3.builder.local,builder.local
# Token binding secret for Telegram/WebApp auth binding.
TOKEN_BINDING_SECRET=change_me_token_binding_secret_please
 
