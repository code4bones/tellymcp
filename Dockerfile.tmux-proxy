FROM golang:1.25-alpine AS build

WORKDIR /src
COPY tmux-proxy-go/go.mod ./tmux-proxy-go/go.mod
COPY tmux-proxy-go/main.go ./tmux-proxy-go/main.go

WORKDIR /src/tmux-proxy-go
ARG TARGETOS=linux
ARG TARGETARCH=amd64
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -trimpath -ldflags="-s -w" -o /out/tmux-proxy-go .

FROM scratch
COPY --from=build /out/tmux-proxy-go /tmux-proxy-go
