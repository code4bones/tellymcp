{
  "manifest_version": 2,
  "name": "TellyMCP Firefox Attach",
  "version": "0.0.1",
  "description": "Attach TellyMCP to an already running Firefox session.",
  "icons": {
    "32": "icon.svg"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "cookies",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "TellyMCP Firefox Attach",
    "default_icon": "icon.svg",
    "default_popup": "popup.html",
    "browser_style": true
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "recorder-content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "recorder-page.js"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tellymcp-firefox-attach@deadragdoll"
    }
  }
}
