{
  "name": "telegram_mcp",
  "version": "1.0.0",
  "description": "Telegram Human-in-the-Loop MCP Server",
  "type": "module",
  "main": "dist/app/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/app/stdio.ts",
    "dev:watch": "tsx watch src/app/stdio.ts",
    "dev:service": "tsx watch src/app/http.ts",
    "dev:tmux-proxy": "tsx watch src/app/tmux-proxy.ts",
    "dev:stdio": "tsx src/app/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/http.js",
    "start:tmux-proxy": "node dist/app/tmux-proxy.js",
    "start:stdio": "node dist/app/stdio.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node -e \"console.log('No tests configured yet')\"",
    "test:watch": "node -e \"console.log('No tests configured yet')\""
  },
  "repository": "gitlab:prj/mcp/telegram_mcp.git",
  "author": "code4bones <p.olesov@code4bones.online>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/storage-redis": "^2.5.1",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "grammy": "^1.38.3",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.10.1",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "socks-proxy-agent": "^8.0.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
