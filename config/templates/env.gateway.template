PAIR_CODE_TTL_SECONDS=300

MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787
MCP_HTTP_PATH=/mcp
# MCP_HTTP_BEARER_TOKEN=
MCP_HTTP_ENABLE_DEBUG_ROUTES=false
MCP_HTTP_ENABLE_PRUNE_ROUTE=false

DISTRIBUTED_MODE=gateway
GATEWAY_PUBLIC_URL=
GATEWAY_WS_URL=
GATEWAY_WS_PATH=/api/gateway/ws
GATEWAY_TOKEN=
GATEWAY_AUTH_TOKEN=

ROOT_PREFIX=/api
PORT=8080
NAMESPACE=mcp
NODE_ID=GWAY

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SCHEME=mcp

